# Copy to .env and fill in. .env is git-ignored — never commit real values.
# Carrier portal credentials are entered in the UI at runtime; they are NEVER stored here.

# --- Carrier login URLs (public, not secret) ---
LM_LOGIN_URL=https://www.libertymutual.com/log-in
GEICO_LOGIN_URL=https://ecams.geico.com/ecams/login

# --- Browser ---
HEADLESS=true                  # set false to watch the automation locally
# Global Chromium launch args (space-separated). Usually empty — per-carrier network args
# (e.g. LM's required --disable-http2) live in each carrier module's LAUNCH_ARGS, not here.
# In Docker you may need: --no-sandbox
CHROMIUM_ARGS=

# --- Frontend origin(s) allowed by CORS (comma-separated) ---
# Defaults to the Vite dev ports if unset: http://localhost:5173,http://localhost:5174
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:5174

# --- Residential proxy (LM tarpits the credential POST from datacenter IPs; a residential
#     egress fixes it — proven end-to-end. Leave unset for direct egress.) ---
# Cloud/prod: a residential proxy service. Local dev: an SSH reverse tunnel through your own
# machine — `ssh -R 1080 user@vm`, then PROXY_SERVER=socks5://127.0.0.1:1080 (no auth). See README.
PROXY_SERVER=                  # e.g. http://gw.provider.com:8080   SECRET
PROXY_USERNAME=                # SECRET
PROXY_PASSWORD=                # SECRET
